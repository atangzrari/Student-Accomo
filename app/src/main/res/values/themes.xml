<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Light Theme -->
    <style name="Theme.HomeLink" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/royal_blue</item>
        <item name="colorPrimaryDark">@color/royal_blue_dark</item>
        <item name="colorPrimaryVariant">@color/royal_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/gray_50</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:statusBarColor">@color/royal_blue</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Dark Theme -->
    <style name="Theme.HomeLink.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/royal_blue_light</item>
        <item name="colorPrimaryDark">@color/royal_blue</item>
        <item name="colorPrimaryVariant">@color/royal_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="android:textColorHint">@color/gray_600</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>

    <style name="Theme.HomeLink.Splash" parent="Theme.HomeLink">
        <item name="android:windowBackground">@color/royal_blue</item>
    </style>

    <!-- TextInput -->
    <style name="HomeLinkTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/royal_blue</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>

    <!-- Primary Button -->
    <style name="HomeLinkButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/royal_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Outline Button -->
    <style name="HomeLinkButton.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/royal_blue</item>
        <item name="android:textColor">@color/royal_blue</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Card -->
    <style name="HomeLinkCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeColor">@color/gray_200</item>
        <item name="strokeWidth">0.5dp</item>
    </style>

    <!-- Toolbar -->
    <style name="HomeLinkToolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/royal_blue</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">#CCFFFFFF</item>
    </style>

    <!-- Chip -->
    <style name="HomeLinkChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

</resources>
