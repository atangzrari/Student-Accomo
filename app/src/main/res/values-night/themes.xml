<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HomeLink" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/royal_blue_light</item>
        <item name="colorPrimaryDark">@color/royal_blue</item>
        <item name="colorPrimaryVariant">@color/royal_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="android:textColorHint">@color/gray_600</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>
    <style name="HomeLinkCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_dark</item>
    </style>
    <style name="HomeLinkTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/royal_blue_light</item>
        <item name="hintTextColor">@color/text_secondary_dark</item>
        <item name="android:textColorHint">@color/gray_600</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>
    <style name="HomeLinkButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/royal_blue_light</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
    <style name="HomeLinkButton.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/royal_blue_light</item>
        <item name="android:textColor">@color/royal_blue_light</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
    <style name="HomeLinkToolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/surface_dark_elevated</item>
        <item name="titleTextColor">@color/text_primary_dark</item>
    </style>
</resources>
